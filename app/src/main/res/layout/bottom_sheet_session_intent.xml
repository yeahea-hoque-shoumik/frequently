<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/bg_1"
    android:paddingBottom="@dimen/spacing_xxl">

    <!-- Drag handle -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingTop="12dp"
        android:paddingBottom="@dimen/spacing_sm">
        <View
            android:layout_width="32dp"
            android:layout_height="3dp"
            android:layout_gravity="center_horizontal"
            android:background="@color/line_2" />
    </FrameLayout>

    <!-- Title -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/intent_sheet_title"
        android:textColor="@color/ink"
        android:textSize="@dimen/text_hero"
        android:fontFamily="sans-serif-medium"
        android:paddingHorizontal="@dimen/screen_padding_h"
        android:paddingBottom="@dimen/spacing_xs" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/intent_sheet_subtitle"
        android:textColor="@color/ink_dim"
        android:textSize="@dimen/text_body_sm"
        android:paddingHorizontal="@dimen/screen_padding_h"
        android:paddingBottom="@dimen/spacing_lg" />

    <!-- Intent list -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_intents"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="@dimen/screen_padding_h"
        android:clipToPadding="false"
        android:nestedScrollingEnabled="false" />

</LinearLayout>
